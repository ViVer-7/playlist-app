{
  "name": "backend",
  "version": "1.0.0",
  "description": "simple backend for the frontend assessment",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start -- delay",
    "start-no-delay": "nest start",
    "start:dev": "nest start --watch -- delay",
    "start:dev-no-delay": "nest start --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.ts$": "ts-jest" },
    "collectCoverageFrom": ["**/*.ts", "!main.ts", "!**/*.module.ts"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^17.3.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.1.16",
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.0"
  }
}
